# Webflow Gate — Umgebungsvariablen

# Webflow Webhook-Signatur-Prüfung
WEBFLOW_WEBHOOK_SECRET=your_webhook_secret_here

# Twenty CRM
TWENTY_API_KEY=your_twenty_api_key_here
TWENTY_BASE_URL=https://crm.docmoritz.academy

# AWeber OAuth
AWEBER_CLIENT_ID=your_aweber_client_id
AWEBER_CLIENT_SECRET=your_aweber_client_secret
AWEBER_ACCOUNT_ID=1450640
AWEBER_TOKEN_FILE=/data/aweber_tokens.json

# Telegram AR-Benachrichtigungen
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID oder TELEGRAM_AUFSICHTSRAT_CHAT_ID
TELEGRAM_CHAT_ID=your_chat_id
